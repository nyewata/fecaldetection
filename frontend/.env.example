# =============================================================================
# Neon — copy this file to `.env.local` and fill in values from Neon Console.
# https://console.neon.tech → your project → Connect / Auth
# =============================================================================

# --- Postgres (required for DB + dashboard data) ---
# In Console: "Connect" → choose branch & database → use the POOLED string
# (hostname contains "-pooler") for Next.js serverless / many short-lived connections.
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Optional: direct (non-pooler) URL — same user/db/password, hostname WITHOUT "-pooler".
# Use for migrations / long-lived connections if your ORM or tool recommends it.
# DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-XXXX.REGION.aws.neon.tech/neondb?sslmode=require"

# --- Neon Auth (when you enable Auth for auth + sessions) ---
# Console: Project → Branch → Auth → Configuration → copy Auth URL
NEON_AUTH_BASE_URL="https://ep-XXXX.neonauth.REGION.aws.neon.tech/neondb/auth"

# At least 32 characters. Generate: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Optional: public site URL (https://your-domain.com) for password-reset emails when Host headers are missing (e.g. some serverless/cron paths).
# NEXT_PUBLIC_SITE_URL="https://localhost:3000"

# --- Remote inference APIs (batch + WebSocket per stage) ---
# Stage 1 fecal gate (defaults to HELMINTH_API_BASE_URL when STAGE1 is unset).
# STAGE1_API_BASE_URL="https://binaryapi.helminthdetect.app"
HELMINTH_API_BASE_URL="https://binaryapi.helminthdetect.app"

# Stage 2 helminth binary screening (Keras batch on dedicated host).
STAGE2_API_BASE_URL="https://stage2api.helminthdetect.app"

# Stage 3 multiclass detection (.pt models on dedicated host).
STAGE3_API_BASE_URL="https://stage3api.helminthdetect.app"

# Public: browser WebSocket origins (wss:// when the site is HTTPS).
NEXT_PUBLIC_STAGE1_WS_ORIGIN="wss://binaryapi.helminthdetect.app"
NEXT_PUBLIC_STAGE2_WS_ORIGIN="wss://stage2api.helminthdetect.app"
NEXT_PUBLIC_STAGE3_WS_ORIGIN="wss://stage3api.helminthdetect.app"

# Legacy single-origin override (still works for Stage 1 if you only set this).
# NEXT_PUBLIC_HELMINTH_WS_ORIGIN="wss://binaryapi.helminthdetect.app"

# --- Cloudflare R2 private image storage (required for prediction image history) ---
# Create an API token scoped to your R2 bucket with Object Read + Write.
R2_S3_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_BUCKET_NAME="helminthdetect"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"

# After adding SQL migrations, prediction history is stored in Neon.
# Run all in order:
# 1) frontend/db/migrations/001_helminth_prediction_runs.sql
# 2) frontend/db/migrations/002_prediction_pipeline_runs.sql
# 3) frontend/db/migrations/003_prediction_pipeline_run_images.sql
# 4) frontend/db/migrations/004_prediction_pipeline_runs_stage3.sql
